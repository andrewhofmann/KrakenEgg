{
  "productName": "KrakenEgg",
  "version": "1.0.0",
  "identifier": "com.krakenegg.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3011",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "KrakenEgg - Total Commander Clone",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "decorations": true,
        "acceptFirstMouse": false,
        "tabbingIdentifier": "main"
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": [
      "icons/SquidAppIcon_Glass_transparent.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256@2x.png",
      "icons/icon.png"
    ],
    "copyright": "Copyright © 2024 KrakenEgg Team",
    "shortDescription": "Modern Total Commander clone for macOS",
    "longDescription": "KrakenEgg is a modern, keyboard-driven Total Commander clone designed primarily for macOS. It features a clean, keyboard-first dual-pane file manager interface with 100% feature parity to Total Commander plus modern enhancements.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
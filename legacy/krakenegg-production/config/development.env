# KrakenEgg Development Environment Configuration

# Development settings
NODE_ENV=development
VITE_DEV_SERVER_PORT=1420
TAURI_DEV_WATCHER=true

# Logging
RUST_LOG=debug
VITE_LOG_LEVEL=info

# Feature flags
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_HOT_RELOAD=true
VITE_ENABLE_MOCK_DATA=true

# Database (if applicable in future)
# DATABASE_URL=sqlite://dev.db

# API endpoints (if applicable in future)
# VITE_API_BASE_URL=http://localhost:3000/api
# VITE_WS_URL=ws://localhost:3000/ws

# Performance settings
VITE_VIRTUAL_SCROLL_THRESHOLD=1000
VITE_FILE_WATCHER_DEBOUNCE=300

# Debug settings
VITE_DEBUG_KEYBOARD_EVENTS=false
VITE_DEBUG_FOCUS_MANAGEMENT=false
VITE_DEBUG_DIALOG_SYSTEM=false
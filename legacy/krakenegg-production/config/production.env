# KrakenEgg Production Environment Configuration

# Production settings
NODE_ENV=production
TAURI_BUILD_OPTIMIZED=true

# Logging
RUST_LOG=info
VITE_LOG_LEVEL=warn

# Feature flags
VITE_ENABLE_DEV_TOOLS=false
VITE_ENABLE_HOT_RELOAD=false
VITE_ENABLE_MOCK_DATA=false

# Performance settings
VITE_VIRTUAL_SCROLL_THRESHOLD=5000
VITE_FILE_WATCHER_DEBOUNCE=150

# Security settings
VITE_ENABLE_CONTENT_SECURITY_POLICY=true
VITE_STRICT_ORIGIN_POLICY=true

# Debug settings (disabled in production)
VITE_DEBUG_KEYBOARD_EVENTS=false
VITE_DEBUG_FOCUS_MANAGEMENT=false
VITE_DEBUG_DIALOG_SYSTEM=false

# Build optimizations
VITE_BUILD_MINIFY=true
VITE_BUILD_SOURCEMAP=false
VITE_BUILD_ANALYZE=false